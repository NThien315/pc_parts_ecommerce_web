@model DOANTKWEB.Models.User
@{
    ViewBag.Title = "Cập nhật hồ sơ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-person-gear"></i> Cập nhật thông tin</h4>
        </div>
        <div class="card-body">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-bold">Họ và tên</label>
                    @Html.TextBoxFor(m => m.FullName, new { @class = "form-control", required = "required" })
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Số điện thoại</label>
                    @Html.TextBoxFor(m => m.Phone, new { @class = "form-control" })
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Địa chỉ giao hàng</label>
                    @Html.TextAreaFor(m => m.Address, new { @class = "form-control", rows = "3" })
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted">Email (Không thể thay đổi)</label>
                    <input type="text" class="form-control" value="@Model.Email" disabled readonly />
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a href="@Url.Action("UserProfile", "Account")" class="btn btn-secondary">Hủy</a>
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                </div>
            }
        </div>
    </div>
</div>