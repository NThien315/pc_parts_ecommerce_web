@{
    ViewBag.Title = "Đăng nhập";
    ViewBag.HideSidebar = true;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0 overflow-hidden" style="width: 900px; border-radius: 15px;">
        <div class="row g-0">
            <div class="col-md-6 d-none d-md-block bg-primary text-white position-relative">

                <img src="~/Images/login-bg.png"
                     style="width: 100%; height: 100%; object-fit: cover; opacity: 0.8;"
                     alt="Login Background" />

                <div class="position-absolute top-50 start-50 translate-middle text-center w-100 p-4" style="z-index: 2; text-shadow: 0 2px 4px rgba(0,0,0,0.8);">
                    <h2 class="fw-bold display-6 text-white">Chào mừng trở lại!</h2>
                    <p class="mt-3 text-white fs-5">Đăng nhập để tiếp tục trải nghiệm mua sắm tuyệt vời tại TTGShop.</p>
                </div>
            </div>

            <div class="col-md-6 bg-white p-5">
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-primary text-uppercase">Đăng nhập</h3>
                    <p class="text-muted small">Điền thông tin đăng nhập của bạn</p>
                </div>

                @if (TempData["LoginError"] != null)
                {
                    <div class="alert alert-danger py-2 fs-6"><i class="bi bi-exclamation-triangle-fill"></i> @TempData["LoginError"]</div>
                }
                @if (TempData["RegisterSuccess"] != null)
                {
                    <div class="alert alert-success py-2 fs-6"><i class="bi bi-check-circle-fill"></i> @TempData["RegisterSuccess"]</div>
                }

                @using (Html.BeginForm("Login", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" id="Email" name="Email" placeholder="name@example.com" required>
                        <label for="Email">Địa chỉ Email</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input type="password" class="form-control" id="Password" name="Password" placeholder="Password" required>
                        <label for="Password">Mật khẩu</label>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe" name="RememberMe" value="true">
                            <label class="form-check-label small text-muted" for="rememberMe">Ghi nhớ đăng nhập</label>
                        </div>

                        <a href="javascript:void(0);" onclick="Swal.fire('Quên mật khẩu?','Vui lòng liên hệ Hotline 1900.1234 hoặc Admin để được cấp lại mật khẩu.','info')" class="text-decoration-none small fw-bold text-primary">
                            Quên mật khẩu?
                        </a>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold text-uppercase shadow-sm mb-3">
                        Đăng nhập
                    </button>
                }

                <div class="text-center pt-3 border-top">
                    <span class="text-muted small">Chưa có tài khoản?</span>
                    <a href="#" data-bs-toggle="modal" data-bs-target="#registerModal" class="fw-bold text-decoration-none ms-1 text-danger">
                        Đăng ký ngay
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Kiểm tra xem có thông báo thành công từ Controller gửi sang không
        var successMessage = '@Html.Raw(TempData["Success"])';
        var errorMessage = '@Html.Raw(TempData["Error"])';

        if (successMessage) {
            Swal.fire({
                icon: 'success',
                title: 'Thành công!',
                text: successMessage,
                showConfirmButton: false,
                timer: 2000
            });
        }

        if (errorMessage) {
            Swal.fire({
                icon: 'error',
                title: 'Lỗi!',
                text: errorMessage
            });
        }
    </script>
}