@{
    ViewBag.Title = "Dashboard - Quản trị hệ thống";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark"><i class="bi bi-speedometer2"></i> Dashboard Quản trị</h3>
        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">
            <i class="bi bi-house-door-fill"></i> Về trang bán hàng
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-primary h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3 text-primary">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted text-uppercase mb-1 small fw-bold">Tài khoản</h6>
                        <h4 class="mb-0 fw-bold text-primary">@ViewBag.TotalUsers</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-success h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3 text-success">
                        <i class="bi bi-box-seam fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted text-uppercase mb-1 small fw-bold">Sản phẩm</h6>
                        <h4 class="mb-0 fw-bold text-success">@ViewBag.TotalProducts</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-warning h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3 text-dark">
                        <i class="bi bi-receipt-cutoff fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted text-uppercase mb-1 small fw-bold">Đơn hàng</h6>
                        <h4 class="mb-0 fw-bold text-dark">@ViewBag.TotalOrders</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 border-start border-4 border-danger h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-danger bg-opacity-10 p-3 rounded-circle me-3 text-danger">
                        <i class="bi bi-currency-dollar fs-3"></i>
                    </div>
                    <div style="min-width: 0;">
                        <h6 class="text-muted text-uppercase mb-1 small fw-bold">Doanh thu</h6>
                        <h4 class="mb-0 fw-bold text-danger text-truncate" title="@String.Format("{0:N0}đ", ViewBag.TotalRevenue)">
                            @String.Format("{0:N0}đ", ViewBag.TotalRevenue)
                        </h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <a href="@Url.Action("Management", "Order")" class="card bg-white border-danger text-danger text-decoration-none shadow-sm h-100 card-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-receipt-cutoff display-4 mb-2"></i>
                    <h5 class="fw-bold">Quản lý Đơn hàng</h5>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="@Url.Action("Index", "Product")" class="card bg-white border-primary text-primary text-decoration-none shadow-sm h-100 card-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-box-seam display-4 mb-2"></i>
                    <h5 class="fw-bold">Quản lý Sản phẩm</h5>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="@Url.Action("Users", "Admin")" class="card bg-white border-info text-info text-decoration-none shadow-sm h-100 card-hover">
                <div class="card-body text-center py-4">
                    <i class="bi bi-people-fill display-4 mb-2"></i>
                    <h5 class="fw-bold">Quản lý Người dùng</h5>
                </div>
            </a>
        </div>
    </div>

    <h5 class="text-muted fw-bold mb-3"><i class="bi bi-gear-fill"></i> Cấu hình</h5>
    <div class="row g-4">
        <div class="col-md-6">
            <a href="@Url.Action("Index", "Category")" class="card bg-light text-dark text-decoration-none shadow-sm h-100 card-hover">
                <div class="card-body p-3 d-flex align-items-center">
                    <i class="bi bi-tags-fill fs-2 me-3 text-success"></i>
                    <h6 class="fw-bold m-0">Danh mục sản phẩm</h6>
                </div>
            </a>
        </div>
        <div class="col-md-6">
            <a href="@Url.Action("Index", "Brand")" class="card bg-light text-dark text-decoration-none shadow-sm h-100 card-hover">
                <div class="card-body p-3 d-flex align-items-center">
                    <i class="bi bi-award-fill fs-2 me-3 text-warning"></i>
                    <h6 class="fw-bold m-0">Thương hiệu</h6>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .card-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1) !important;
        transition: 0.2s;
    }
</style>