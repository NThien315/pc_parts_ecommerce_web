@model DOANTKWEB.Models.User
@{ ViewBag.Title = "Thêm người dùng"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow border-0">
        <div class="card-header bg-success text-white fw-bold">Thêm người dùng mới</div>
        <div class="card-body">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label>Họ và Tên</label>
                    @Html.TextBoxFor(m => m.FullName, new { @class = "form-control", required = "required" })
                </div>
                <div class="mb-3">
                    <label>Email (Tài khoản)</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email", required = "required" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>
                <div class="mb-3">
                    <label>Mật khẩu (Để trống mặc định 123456)</label>
                    @Html.PasswordFor(m => m.PasswordHash, new { @class = "form-control" })
                </div>
                <div class="mb-3">
                    <label>Quyền hạn</label>
                    <select name="Role" class="form-select">
                        <option value="User">User (Khách hàng)</option>
                        <option value="Admin">Admin (Quản trị viên)</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-success w-100">Lưu người dùng</button>
                <a href="@Url.Action("Users")" class="btn btn-link w-100 mt-2">Quay lại</a>
            }
        </div>
    </div>
</div>