@model IEnumerable<DOANTKWEB.Models.User>
@{ ViewBag.Title = "Quản lý người dùng"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="container mt-4 mb-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-bold"><i class="bi bi-people-fill me-2"></i>Quản lý người dùng</h4>
            <a href="@Url.Action("UserCreate")" class="btn btn-light text-primary fw-bold">
                <i class="bi bi-plus-lg"></i> Thêm mới
            </a>
        </div>

        <div class="card-body p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success"><i class="bi bi-check-circle"></i> @Html.Raw(TempData["Success"])</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> @Html.Raw(TempData["Error"])</div>
            }

            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead class="table-light text-center">
                        <tr>
                            <th>ID</th>
                            <th>Họ tên</th>
                            <th>Email</th>
                            <th>Điện thoại</th>
                            <th>Quyền</th>
                            <th style="width: 250px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">#@item.UserID</td>
                                <td class="fw-bold text-primary">@item.FullName</td>
                                <td>@item.Email</td>
                                <td class="text-center">@item.Phone</td>
                                <td class="text-center">
                                    <span class="badge @(item.Role == "Admin" ? "bg-danger" : "bg-success")">@item.Role</span>
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("UserEdit", new { id = item.UserID })" class="btn btn-primary btn-sm" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <button class="btn btn-warning btn-sm text-dark" onclick="confirmReset(@item.UserID, '@item.FullName')" title="Reset Pass">
                                        <i class="bi bi-key"></i>
                                    </button>

                                    <button class="btn btn-danger btn-sm" onclick="confirmDelete(@item.UserID, '@item.FullName')" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<form id="action-form" method="post" style="display:none;">@Html.AntiForgeryToken() <input type="hidden" name="id" id="action-id" /></form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Xử lý Reset Pass
        function confirmReset(id, name) {
            Swal.fire({
                title: 'Reset mật khẩu?',
                text: `Đặt lại mật khẩu của "${name}" về 123456?`,
                icon: 'warning', showCancelButton: true, confirmButtonText: 'Đồng ý',
            }).then((result) => {
                if (result.isConfirmed) {
                    var form = document.getElementById('action-form');
                    form.action = '@Url.Action("ResetPassword", "Admin")';
                    document.getElementById('action-id').value = id;
                    form.submit();
                }
            });
        }

        // Xử lý Xóa User
        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Xóa người dùng?',
                text: `Hành động này không thể hoàn tác! Xóa user "${name}"?`,
                icon: 'error', showCancelButton: true, confirmButtonText: 'Xóa luôn', confirmButtonColor: '#d33',
            }).then((result) => {
                if (result.isConfirmed) {
                    var form = document.getElementById('action-form');
                    form.action = '@Url.Action("UserDelete", "Admin")';
                    document.getElementById('action-id').value = id;
                    form.submit();
                }
            });
        }
    </script>
}