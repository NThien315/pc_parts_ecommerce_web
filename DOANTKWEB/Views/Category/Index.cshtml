@model IEnumerable<DOANTKWEB.Models.Category>
@{
    ViewBag.Title = "Quản lý Danh mục";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="text-primary fw-bold"><i class="bi bi-tags-fill"></i> Quản lý Danh mục</h3>
        <button type="button" class="btn btn-success shadow-sm" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="bi bi-plus-lg"></i> Thêm danh mục
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle"></i> @TempData["Success"] <button class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle"></i> @TempData["Error"] <button class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Tên Danh mục</th>
                        <th class="text-center">Số lượng SP</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">#@item.CategoryID</td>
                            <td class="fw-bold text-primary">@item.CategoryName</td>
                            <td class="text-center">
                                <span class="badge bg-secondary rounded-pill">
                                    @item.Products.Count() sản phẩm
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <button class="btn btn-sm btn-warning"
                                            onclick="openEditModal('@item.CategoryID', '@item.CategoryName')">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    <form action="@Url.Action("Delete", "Category")" method="post" id="delCat-@item.CategoryID">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.CategoryID" />
                                        <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelCat(@item.CategoryID)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold">Thêm Danh mục</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="@Url.Action("Create", "Category")" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên danh mục</label>
                        <input type="text" name="CategoryName" class="form-control" required placeholder="Ví dụ: Laptop, PC..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">Lưu lại</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold">Sửa Danh mục</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="@Url.Action("Edit", "Category")" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="editCatId" name="CategoryID" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên danh mục</label>
                        <input type="text" id="editCatName" name="CategoryName" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-warning">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // 1. Hàm mở Modal Sửa
    function openEditModal(id, name) {
        document.getElementById('editCatId').value = id;
        document.getElementById('editCatName').value = name;

        var myModal = new bootstrap.Modal(document.getElementById('editModal'));
        myModal.show();
    }

    // 2. Hàm Xóa
    function confirmDelCat(id) {
        Swal.fire({
            title: 'Xóa danh mục này?',
            text: "Chỉ xóa được khi danh mục không có sản phẩm.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            confirmButtonText: 'Xóa ngay',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('delCat-' + id).submit();
            }
        })
    }
</script>