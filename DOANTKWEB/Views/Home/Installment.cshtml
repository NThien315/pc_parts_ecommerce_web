@{
    ViewBag.Title = "Hướng dẫn trả góp";
}

<div class="container mt-4 mb-5">

    <style>
        .guide-wrapper {
            background: #ffffff;
            padding: 30px;
            border-radius: 14px;
            box-shadow: 0 0 20px rgba(0,0,0,0.06);
        }

        .guide-title {
            font-size: 1.7rem;
            font-weight: 700;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .guide-title i {
                font-size: 1.7rem;
                color: #0d6efd;
            }

        .step-box {
            background: #f8f9fa;
            padding: 22px;
            border-radius: 12px;
            box-shadow: 0 0 14px rgba(0,0,0,0.05);
            margin-bottom: 20px;
            display: flex;
            gap: 18px;
            transition: 0.2s;
        }

            .step-box:hover {
                transform: translateY(-4px);
                background: #eef5ff;
            }

            .step-box i {
                font-size: 2.4rem;
                color: #0d6efd;
            }

        .bank-box {
            text-align: center;
            padding: 20px;
            border-radius: 12px;
            background: #ffffff;
            box-shadow: 0 0 12px rgba(0,0,0,0.06);
            transition: 0.2s;
        }

            .bank-box:hover {
                transform: translateY(-4px);
            }

            .bank-box img {
                max-height: 50px;
                object-fit: contain;
            }

        .register-box {
            background: #e9f7ef;
            border-left: 5px solid #28a745;
            padding: 20px;
            border-radius: 10px;
            margin-top: 25px;
        }
    </style>

    <div class="guide-wrapper">

        <div class="guide-title">
            <i class="bi bi-credit-card"></i>
            Hướng dẫn mua hàng trả góp
        </div>

        <p class="mb-4">
            Khách hàng có thể dễ dàng mua hàng trả góp với thủ tục nhanh gọn, lãi suất thấp.
            Chúng tôi hỗ trợ trả góp qua <strong>thẻ tín dụng</strong> và <strong>công ty tài chính</strong> như FE Credit, HD Saison...
        </p>

        <h4 class="fw-bold mb-3">✦ Quy trình mua hàng trả góp</h4>

        <div class="step-box">
            <i class="bi bi-cart-check"></i>
            <div>
                <h5 class="fw-bold">Bước 1: Chọn sản phẩm muốn mua</h5>
                <p>Chọn sản phẩm trên website hoặc cửa hàng mà bạn muốn trả góp.</p>
            </div>
        </div>

        <div class="step-box">
            <i class="bi bi-ui-checks-grid"></i>
            <div>
                <h5 class="fw-bold">Bước 2: Chọn hình thức trả góp</h5>
                <p>Bạn có thể chọn trả góp qua thẻ tín dụng hoặc công ty tài chính.</p>
            </div>
        </div>

        <div class="step-box">
            <i class="bi bi-file-earmark-text"></i>
            <div>
                <h5 class="fw-bold">Bước 3: Cung cấp hồ sơ</h5>
                <p>CMND/CCCD + bằng lái xe hoặc hộ khẩu (nếu chọn công ty tài chính).</p>
            </div>
        </div>

        <div class="step-box">
            <i class="bi bi-person-check"></i>
            <div>
                <h5 class="fw-bold">Bước 4: Duyệt hồ sơ & nhận hàng</h5>
                <p>Duyệt nhanh 10–30 phút, nhận sản phẩm ngay khi được phê duyệt.</p>
            </div>
        </div>

        <!-- PAYMENT OPTIONS -->
        <h4 class="fw-bold mt-5 mb-3">✦ Các phương thức trả góp</h4>

        <div class="row mb-4">
            <div class="col-lg-4 col-md-6 mb-3">
                <div class="bank-box">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/4/41/Visa_Logo.png" />
                    <p class="mt-2 fw-bold">Trả góp qua thẻ Visa</p>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 mb-3">
                <div class="bank-box">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" />
                    <p class="mt-2 fw-bold">Trả góp qua Mastercard</p>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 mb-3">
                <div class="bank-box">
                    <img src="data:image/png;base64," />
                    <p class="mt-2 fw-bold">Trả góp qua HD Saison</p>
                </div>
            </div>
        </div>

        <div class="register-box mt-4">
            <h5 class="fw-bold">Lưu ý dành cho khách hàng:</h5>
            <ul>
                <li>Không áp dụng trả góp cho sản phẩm khuyến mãi shock.</li>
                <li>Đơn hàng trả góp tối thiểu: <strong>3.000.000 VNĐ</strong>.</li>
                <li>Không giữ giấy tờ gốc – thủ tục nhanh, an toàn.</li>
            </ul>
        </div>

        <div class="text-center mt-5">
            <a href="@Url.Action("Contact", "Home")" class="btn btn-primary btn-lg px-4">
                <i class="bi bi-envelope"></i> Liên hệ tư vấn trả góp
            </a>
        </div>

    </div>

</div>