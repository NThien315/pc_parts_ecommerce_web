@model DOANTKWEB.Models.Product

@{
    ViewBag.Title = "Tạo sản phẩm mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4 mb-5">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Tạo sản phẩm mới</h4>
        </div>
        <div class="card-body">

            @using (Html.BeginForm("Create", "Product", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()

                <div class="form-horizontal">
                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    <div class="row mb-3">
                        <div class="col-md-6">
                            @Html.LabelFor(model => model.ProductName, "Tên sản phẩm", new { @class = "form-label fw-bold" })
                            @Html.EditorFor(model => model.ProductName, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                            @Html.ValidationMessageFor(model => model.ProductName, "", new { @class = "text-danger" })
                        </div>
                        <div class="col-md-6">
                            @Html.LabelFor(model => model.Images, "Hình ảnh đại diện", new { @class = "form-label fw-bold" })
                            <input type="file" name="ImageUpload" class="form-control" accept="image/*" />
                            @Html.ValidationMessageFor(model => model.Images, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Danh mục</label>
                            @Html.DropDownList("CategoryID", (IEnumerable<SelectListItem>)ViewBag.CategorySelect, "--- Chọn danh mục ---", new { @class = "form-select", required = "required" })
                            @Html.ValidationMessageFor(model => model.CategoryID, "", new { @class = "text-danger" })
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Thương hiệu</label>
                            @Html.DropDownList("BrandID", (IEnumerable<SelectListItem>)ViewBag.BrandSelect, "--- Chọn thương hiệu ---", new { @class = "form-select", required = "required" })
                            @Html.ValidationMessageFor(model => model.BrandID, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            @Html.LabelFor(model => model.Price, "Giá gốc (VNĐ)", new { @class = "form-label fw-bold" })
                            @Html.EditorFor(model => model.Price, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0" } })
                            @Html.ValidationMessageFor(model => model.Price, "", new { @class = "text-danger" })
                        </div>
                        <div class="col-md-6">
                            @Html.LabelFor(model => model.DiscountPrice, "Giá khuyến mãi (VNĐ)", new { @class = "form-label fw-bold" })
                            @Html.EditorFor(model => model.DiscountPrice, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0", placeholder = "Để trống nếu không giảm" } })
                            @Html.ValidationMessageFor(model => model.DiscountPrice, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            @Html.LabelFor(model => model.StockQuantity, "Số lượng tồn kho", new { @class = "form-label fw-bold" })
                            @Html.EditorFor(model => model.StockQuantity, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0" } })
                            @Html.ValidationMessageFor(model => model.StockQuantity, "", new { @class = "text-danger" })
                        </div>
                        <div class="col-md-6">
                            @Html.LabelFor(model => model.WarrantyMonths, "Bảo hành (tháng)", new { @class = "form-label fw-bold" })
                            @Html.EditorFor(model => model.WarrantyMonths, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0" } })
                            @Html.ValidationMessageFor(model => model.WarrantyMonths, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(model => model.Description, "Mô tả sản phẩm", new { @class = "form-label fw-bold" })
                        @Html.TextAreaFor(model => model.Description, new { @class = "form-control", rows = "5" })
                        @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger" })
                    </div>

                    <hr />
                    <h5 class="text-primary mb-3"><i class="bi bi-cpu"></i> Thông số kỹ thuật (Dành cho PC/Laptop)</h5>

                    <div class="row mb-3">
                        <div class="col-md-3 mb-3">
                            <label class="form-label">CPU</label>
                            @Html.EditorFor(model => model.CPU, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">RAM</label>
                            @Html.EditorFor(model => model.RAM, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Ổ cứng (Storage)</label>
                            @Html.EditorFor(model => model.Storage, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Card đồ họa (GPU)</label>
                            @Html.EditorFor(model => model.GPU, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Mainboard</label>
                            @Html.EditorFor(model => model.Mainboard, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Nguồn (PSU)</label>
                            @Html.EditorFor(model => model.PSU, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Vỏ Case</label>
                            @Html.EditorFor(model => model.Case, new { htmlAttributes = new { @class = "form-control" } })
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a href="@Url.Action("Index", "Product")" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-lg"></i> Tạo sản phẩm
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>