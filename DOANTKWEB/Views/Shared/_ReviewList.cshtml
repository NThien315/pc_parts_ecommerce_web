@model IEnumerable<DOANTKWEB.Models.Review>

@{
    Layout = null; // partial view không dùng layout
    int productId = ViewData["productId"] != null ? (int)ViewData["productId"] : 0;
}

<h3>Đánh giá sản phẩm</h3>

@if (Session["UserID"] != null)
{
    <form action="/Review/Add" method="post" class="mb-3">

        <!-- TRUYỀN LÊN CONTROLLER -->
        <input type="hidden" name="productId" value="@productId" />

        <div class="form-group">
            <label>Đánh giá (1–5)</label>
            <select name="rating" class="form-control" required>
                <option value="5">⭐️⭐️⭐️⭐️⭐️</option>
                <option value="4">⭐️⭐️⭐️⭐️</option>
                <option value="3">⭐️⭐️⭐️</option>
                <option value="2">⭐️⭐️</option>
                <option value="1">⭐️</option>
            </select>
        </div>

        <div class="form-group">
            <label>Nội dung</label>
            <textarea name="content" class="form-control" rows="3" required></textarea>
        </div>

        <button type="submit" class="btn btn-primary mt-2">Gửi đánh giá</button>
    </form>
}
else
{
    <p class="text-muted">
        Bạn cần <a href="/Account/Login">đăng nhập</a> để đánh giá.
    </p>
}

<hr />

@if (!Model.Any())
{
    <p>Chưa có đánh giá nào cho sản phẩm này.</p>
}
else
{
    foreach (var r in Model)
    {
        <div class="border p-2 mb-2 rounded">
            <strong>@r.User.FullName</strong>

            <span class="text-warning ms-2">
                @for (int i = 0; i < r.Rating; i++)
                {
                    @:★
                }
            </span>

            <p>@r.Comment</p>

            <small class="text-muted">@r.ReviewDate.ToString("dd/MM/yyyy HH:mm")</small>

            @if (Session["UserID"] != null && (int)Session["UserID"] == r.UserID)
            {
                <a href="/Review/Delete/@r.ReviewID" class="btn btn-sm btn-danger float-end">Xóa</a>
            }
        </div>
    }
}
