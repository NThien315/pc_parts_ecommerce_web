@{
    ViewBag.Title = "Xây dựng cấu hình PC";
}

<div class="container mt-4 mb-5">

    <style>
        .builder-wrapper {
            background: #ffffff;
            padding: 25px;
            border-radius: 14px;
            box-shadow: 0 0 22px rgba(0,0,0,0.06);
        }

        .builder-title {
            font-size: 1.6rem;
            font-weight: 700;
            display: flex;
            gap: 10px;
            align-items: center;
            margin-bottom: 25px;
        }

            .builder-title i {
                font-size: 1.7rem;
                color: #0d6efd;
            }

        .part-box {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 18px;
            margin-bottom: 18px;
            box-shadow: 0 0 14px rgba(0,0,0,0.06);
        }

            .part-box label {
                font-weight: 600;
            }

        .summary-box {
            background: #eef7ff;
            border-radius: 12px;
            padding: 18px;
            box-shadow: 0 0 14px rgba(0,0,0,0.06);
        }

        .part-img {
            width: 100%;
            height: 160px;
            object-fit: contain;
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,0,0,0.06);
        }
    </style>

    <div class="builder-wrapper">

        <div class="builder-title">
            <i class="bi bi-pc-display"></i>
            Xây dựng cấu hình PC theo nhu cầu
        </div>

        <p class="mb-3">
            Hãy chọn linh kiện phù hợp để tạo ra bộ PC theo sở thích của bạn. Hệ thống sẽ tự động tính tổng chi phí.
        </p>

        <div class="row">

            <!-- ================= LEFT: CHỌN LINH KIỆN ================= -->
            <div class="col-lg-7">

                @helper RenderPartSection(string id, string label, string icon)
                {
                    <div class="part-box mb-3 p-3 bg-light rounded shadow-sm">
                        <label class="fw-bold mb-2"><i class="@icon text-primary me-2"></i> @label</label>

                        <div class="input-group">
                            <input type="text" id="@(id)-display" class="form-control bg-white"
                                   value="-- Chưa chọn --" readonly />

                            <input type="number" id="@(id)-qty" class="form-control text-center fw-bold"
                                   value="1" min="1" max="10" style="max-width: 80px;"
                                   onchange="updateTotal()" disabled />

                            <button class="btn btn-primary" type="button" onclick="openComponentModal('@id', '@label')">Chọn</button>
                            <button class="btn btn-outline-danger" type="button" onclick="resetPart('@id')"><i class="bi bi-trash"></i></button>
                        </div>

                        <div class="d-flex justify-content-between mt-2 px-1" style="font-size: 0.9rem;">
                            <span class="text-muted">Đơn giá: <strong id="@(id)-unit-price">0 đ</strong></span>
                            <span class="text-danger fw-bold">Thành tiền: <strong id="@(id)-line-total">0 đ</strong></span>
                        </div>

                        <input type="hidden" id="@id" data-part-type="@id" value="" data-price="0" data-img="" />
                        <img id="@(id)-img"
                             class="part-img mt-2 border rounded p-2 bg-white"
                             style="display:none; height: 100px; object-fit: contain;"
                             src=""
                             onerror="this.onerror=null; this.src='https://placehold.co/400x300?text=No+Image';" />
                    </div>
                }

                @RenderPartSection("cpu", "Vi xử lý (CPU)", "bi bi-cpu")
                @RenderPartSection("main", "Bo mạch chủ (Mainboard)", "bi bi-motherboard")
                @RenderPartSection("ram", "Bộ nhớ trong (RAM)", "bi bi-memory")
                @RenderPartSection("gpu", "Card màn hình (VGA)", "bi bi-gpu-card")
                @RenderPartSection("ssd", "Ổ cứng (SSD/HDD)", "bi bi-device-hdd")
                @RenderPartSection("psu", "Nguồn máy tính (PSU)", "bi bi-plug")
                @RenderPartSection("case", "Vỏ máy tính (Case)", "bi bi-pc")

            </div>

            <!-- ================= RIGHT: TỔNG KẾT ================= -->
            <div class="col-lg-5">

                <div class="summary-box">
                    <h5 class="fw-bold mb-3">Tổng chi phí dự kiến:</h5>

                    <h3 id="totalPrice" class="text-danger fw-bold">0 VNĐ</h3>

                    <p class="mt-3">
                        Kiểm tra lại các linh kiện đã chọn trước khi đặt hàng.
                    </p>

                    <button class="btn btn-primary btn-lg w-100 mt-2" onclick="addConfigToCart()">Thêm cấu hình vào giỏ hàng</button>

                </div>

            </div>

        </div>

    </div>

</div>

<div class="modal fade" id="componentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="bi bi-search me-2"></i>Chọn linh kiện: <span id="currentPartName" class="fw-bold"></span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="modalPartType" value="" />

                <div class="input-group mb-3">
                    <input type="text" id="modalSearch" class="form-control" placeholder="Nhập tên sản phẩm để tìm..." onkeypress="if(event.keyCode==13) loadComponentList(1)">
                    <button class="btn btn-primary" type="button" onclick="loadComponentList(1)">
                        <i class="bi bi-search"></i> Tìm kiếm
                    </button>
                </div>

                <div id="componentListContainer" style="min-height: 200px;">
                    <div class="text-center text-muted mt-5">Đang tải dữ liệu...</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Danh sách linh kiện quản lý
        const parts = ['cpu', 'main', 'ram', 'gpu', 'ssd', 'psu', 'case'];

        let myModalObj = null;
        let currentSelectingPart = '';

        // 1. HÀM MỞ MODAL
        function openComponentModal(partType, partName) {
            console.log("Đang mở modal cho: " + partType);

            currentSelectingPart = partType;

            // Reset giao diện Modal
            if(document.getElementById('currentPartName'))
                document.getElementById('currentPartName').innerText = partName;

            document.getElementById('modalPartType').value = partType;
            document.getElementById('modalSearch').value = '';
            document.getElementById('componentListContainer').innerHTML = '';

            // Load dữ liệu mới
            loadComponentList(1);

            // Khởi tạo Modal thủ công
            const modalEl = document.getElementById('componentModal');
            if(modalEl) {
                // Hủy instance cũ nếu có để tránh xung đột
                const oldModal = bootstrap.Modal.getInstance(modalEl);
                if(oldModal) oldModal.dispose();

                myModalObj = new bootstrap.Modal(modalEl);
                myModalObj.show();
            }
        }

        // 2. GỌI AJAX LOAD DANH SÁCH
        function loadComponentList(page) {
            const partType = document.getElementById('modalPartType').value;
            const search = document.getElementById('modalSearch').value;
            const container = document.getElementById('componentListContainer');

            container.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div><div class="mt-2">Đang tải dữ liệu...</div></div>';

            // Dùng jQuery ($) để gọi Ajax
            $.ajax({
                url: '@Url.Action("GetComponents", "Product")',
                type: 'GET',
                data: { partType: partType, search: search, page: page },
                success: function (data) {
                    container.innerHTML = data;
                },
                error: function (xhr, status, error) {
                    console.error("Lỗi Ajax:", error);
                    container.innerHTML = '<div class="text-center text-danger py-3">Lỗi kết nối Server! (Xem Console F12)</div>';
                }
            });
        }

        // 3. XỬ LÝ CHỌN SẢN PHẨM
        // Dùng sự kiện click toàn cục để không bị mất sự kiện khi Ajax load lại
        document.addEventListener('click', function(e) {
            const btn = e.target.closest('.btn-select-part');

            if (btn) {
                const partType = currentSelectingPart;

                // 1. Gán ID và Giá vào Input ẩn
                const idInput = document.getElementById(partType);
                if(idInput) {
                    idInput.value = btn.dataset.productId;
                    idInput.dataset.price = btn.dataset.price;
                }

                // 2. Hiển thị tên
                const displayInput = document.getElementById(partType + '-display');
                if(displayInput) displayInput.value = btn.dataset.productName;

                // 3. Bật nhập số lượng
                const qtyInput = document.getElementById(partType + '-qty');
                if(qtyInput) {
                    qtyInput.disabled = false;
                    qtyInput.value = 1;
                }

                // 4. Hiển thị ảnh
                const imgDisplay = document.getElementById(partType + '-img');
                if(imgDisplay) {
                    imgDisplay.src = btn.dataset.img;
                    imgDisplay.style.display = 'block';
                }

                // 5. Tính tiền & Đóng modal
                updateTotal();
                if(myModalObj) myModalObj.hide();
            }
        });

        // 4. RESET DÒNG
        function resetPart(id) {
            const idInput = document.getElementById(id);
            if(!idInput) return;

            idInput.value = "";
            idInput.dataset.price = "0";

            document.getElementById(id + '-display').value = "-- Chưa chọn --";

            const qtyInput = document.getElementById(id + '-qty');
            if(qtyInput) {
                qtyInput.value = "1";
                qtyInput.disabled = true;
            }

            const imgDisplay = document.getElementById(id + '-img');
            if(imgDisplay) imgDisplay.style.display = 'none';

            updateTotal();
        }

        // 5. TÍNH TỔNG TIỀN
        function updateTotal() {
            let total = 0;
            parts.forEach(type => {
                const el = document.getElementById(type);
                // Chỉ tính nếu ô đó tồn tại và đã có giá trị (ID sản phẩm)
                if(el && el.value) {
                    const price = parseFloat(el.dataset.price) || 0;
                    const qtyEl = document.getElementById(type + '-qty');
                    const qty = qtyEl ? (parseInt(qtyEl.value) || 1) : 1;

                    const subtotal = price * qty;
                    total += subtotal;

                    // Update giá con
                    const linePrice = document.getElementById(type + '-unit-price');
                    const lineTotal = document.getElementById(type + '-line-total');

                    if(linePrice) linePrice.innerText = price.toLocaleString() + ' đ';
                    if(lineTotal) lineTotal.innerText = subtotal.toLocaleString() + ' đ';
                }
            });

            document.getElementById('totalPrice').innerText = total.toLocaleString() + ' VNĐ';
        }

        // 6. THÊM VÀO GIỎ
        function addConfigToCart() {
            let ids = [], qtys = [];
            parts.forEach(type => {
                const el = document.getElementById(type);
                if(el && el.value) {
                    ids.push(el.value);
                    const qty = document.getElementById(type + '-qty').value;
                    qtys.push(qty);
                }
            });

            if(ids.length === 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Chưa chọn linh kiện!',
                    text: 'Vui lòng chọn ít nhất 1 linh kiện.'
                });
                return;
            }

            window.location.href = `/Cart/AddMultiple?productIds=${ids.join(',')}&quantities=${qtys.join(',')}`;
        }
    </script>
}